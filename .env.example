# Copy this file to .env and fill in your values
# Never commit .env — it's in .gitignore

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Used by both JobOps (scoring) and the profile-editor (keyword analysis)
OPENROUTER_API_KEY=your_key_here

# Model used for scoring jobs and "Analyse with AI"
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Adzuna (optional — adds more Canadian listings) ───────────────────────────
ADZUNA_APP_ID=your_id_here
ADZUNA_APP_KEY=your_key_here

# ── Email ─────────────────────────────────────────────────────────────────────
# GMAIL_FROM: account doing the sending (needs 2FA + App Password)
# GMAIL_TO:   where the daily digest lands (can be the same address)
GMAIL_FROM=sender@gmail.com
GMAIL_TO=recipient@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Profile editor URL — shown as "Edit profile" link in email footer ─────────
# Set to the IP/hostname of the machine running Docker, e.g. http://192.168.1.100:3006
SITE_URL=

# ── Telegram (optional — leave blank to disable) ──────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
